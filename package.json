{
  "name": "cacti-demos",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "utils/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "configure": "yarn install && yarn build:dev:backend",
    "lint": "run-s format:eslint format:prettier spellcheck",
    "format:eslint": "eslint '**/*.{js,ts}' --quiet --fix",
    "format:prettier": "prettier --write --config .prettierrc.js './**/{*.ts,*.js,*.json}'",
    "spellcheck": "cspell lint --no-progress '*/*/src/**/*.{js,ts}'",
    "build:dev:backend": "tsc --build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "cspell": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lerna": "^8.1.2",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "typescript": "^5.4.5"
  }
}
