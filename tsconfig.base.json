{
  "include": ["src", "src/**/*.json"],
  "compilerOptions": {
    "incremental": true,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "dom"],
    "declaration": true,
    "removeComments": false,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "inlineSourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false
  }
}
